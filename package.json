{
  "name": "finance-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n \"backend,frontend\" -c \"blue,green\" \"bun run dev:backend\" \"bun run dev:frontend\"",
    "dev:backend": "cd backend && bun run start:dev",
    "dev:frontend": "cd frontend && bun run dev",
    "build": "bun run build:backend && bun run build:frontend",
    "build:backend": "cd backend && bun run build",
    "build:frontend": "cd frontend && bun run build",
    "install:all": "cd backend && bun install && cd ../frontend && bun install",
    "lint": "bun run lint:backend && bun run lint:frontend",
    "lint:backend": "cd backend && bun run lint",
    "lint:frontend": "cd frontend && bun run lint"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "lint-staged": "^16.2.7",
    "simple-git-hooks": "^2.13.1"
  },
  "simple-git-hooks": {
    "pre-commit": "bunx lint-staged"
  },
  "lint-staged": {
    "backend/src/**/*.ts": [
      "bash -c 'cd backend && bunx eslint --fix'"
    ],
    "frontend/src/**/*.{ts,vue}": [
      "bash -c 'cd frontend && bunx eslint --fix'"
    ]
  }
}
