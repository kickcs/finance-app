{
  "expo": {
    "name": "Finance",
    "slug": "finance-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "finance",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.hamkor.finance",
      "supportsTablet": false
    },
    "android": {
      "package": "com.hamkor.finance",
      "predictiveBackGestureEnabled": true
    },
    "platforms": [
      "ios",
      "android"
    ],
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-splash-screen",
      [
        "expo-notifications",
        {
          "color": "#0A84FF"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Доступ к камере нужен для сканирования чеков"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Доступ к фото нужен для загрузки чеков"
        }
      ]
    ],
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
