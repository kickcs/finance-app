# Production environment template.
# Rendered on the server via `envsubst` during deploy:
#   envsubst < docker/env.prod.template > .env
#
# All ${VAR} placeholders MUST be exported in the deploy step's environment
# before envsubst runs. Add a new placeholder here AND export it in deploy.yml.

# === Image & registry ===
GITHUB_REPOSITORY=${GITHUB_REPOSITORY}
GHCR_IMAGE_TAG=${GHCR_IMAGE_TAG}

# === Database ===
DATABASE_NAME=my_finance
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=${DATABASE_PASSWORD}
DATABASE_SYNCHRONIZE=false

# === Auth ===
JWT_SECRET=${JWT_SECRET}
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
CORS_ORIGIN=${CORS_ORIGIN}

# === LemonSqueezy (payments) ===
LEMONSQUEEZY_API_KEY=${LEMONSQUEEZY_API_KEY}
LEMONSQUEEZY_WEBHOOK_SECRET=${LEMONSQUEEZY_WEBHOOK_SECRET}
LEMONSQUEEZY_STORE_ID=${LEMONSQUEEZY_STORE_ID}
LEMONSQUEEZY_PREMIUM_MONTHLY_VARIANT_ID=${LEMONSQUEEZY_PREMIUM_MONTHLY_VARIANT_ID}
LEMONSQUEEZY_PREMIUM_YEARLY_VARIANT_ID=${LEMONSQUEEZY_PREMIUM_YEARLY_VARIANT_ID}

# === OpenAI (receipt OCR) ===
OPENAI_API_KEY=${OPENAI_API_KEY}

# === Telegram import (optional) ===
TELEGRAM_IMPORT_BOT_TOKEN=${TELEGRAM_IMPORT_BOT_TOKEN}
TELEGRAM_IMPORT_BOT_USERNAME=${TELEGRAM_IMPORT_BOT_USERNAME}
TELEGRAM_IMPORT_WEBHOOK_SECRET=${TELEGRAM_IMPORT_WEBHOOK_SECRET}
TELEGRAM_IMPORT_WEBHOOK_URL=${TELEGRAM_IMPORT_WEBHOOK_URL}

# === Web push (VAPID) ===
VAPID_PUBLIC_KEY=${VAPID_PUBLIC_KEY}
VAPID_PRIVATE_KEY=${VAPID_PRIVATE_KEY}
VAPID_SUBJECT=${VAPID_SUBJECT}

# === Observability (Grafana Cloud via Alloy) ===
GRAFANA_CLOUD_API_KEY=${GRAFANA_CLOUD_API_KEY}
GRAFANA_CLOUD_PROMETHEUS_URL=${GRAFANA_CLOUD_PROMETHEUS_URL}
GRAFANA_CLOUD_PROMETHEUS_USER=${GRAFANA_CLOUD_PROMETHEUS_USER}
GRAFANA_CLOUD_LOKI_URL=${GRAFANA_CLOUD_LOKI_URL}
GRAFANA_CLOUD_LOKI_USER=${GRAFANA_CLOUD_LOKI_USER}
GRAFANA_CLOUD_TEMPO_URL=${GRAFANA_CLOUD_TEMPO_URL}
GRAFANA_CLOUD_TEMPO_USER=${GRAFANA_CLOUD_TEMPO_USER}
OTEL_EXPORTER_OTLP_ENDPOINT=http://finance-alloy:4317
